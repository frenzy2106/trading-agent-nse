# Copy this file to .env and fill in real values. Never commit .env.

# Kite Connect — get from https://developers.kite.trade
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret

# ── LLM provider selection ─────────────────────────────────────────────────
# One of: deepseek (default, cheapest), groq, anthropic
LLM_PROVIDER=deepseek

# DeepSeek — get from https://platform.deepseek.com (default; cheap + tool calls + 1M context)
DEEPSEEK_API_KEY=your_deepseek_api_key
# deepseek-chat = V4 Flash non-thinking (default). deepseek-reasoner = V4 Flash thinking.
DEEPSEEK_MODEL=deepseek-chat

# Groq — get from https://console.groq.com (legacy / fast + free tier with daily cap)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=openai/gpt-oss-120b

# Anthropic — get from https://console.anthropic.com (premium, only set if using LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=your_anthropic_api_key
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Optional: log level for agent + tools (DEBUG / INFO / WARNING)
LOG_LEVEL=WARNING

# ── LangSmith observability (optional) ─────────────────────────────────────
# When LANGSMITH_TRACING=true and a key is set, every LLM call from the agent
# is auto-traced and viewable at https://smith.langchain.com. Sign up free at
# the same URL — dev tier is 5k traces/month.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=trading-agent-nse
