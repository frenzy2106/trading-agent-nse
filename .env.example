# Copy this file to .env and fill in real values. Never commit .env.

# Kite Connect — get from https://developers.kite.trade
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret

# Groq (LLM provider) — get from https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# Default model. openai/gpt-oss-120b has been the most reliable on tool calls;
# llama-3.3-70b-versatile works but occasionally fumbles tool-call format with
# longer system prompts.
GROQ_MODEL=openai/gpt-oss-120b

# Optional: log level for agent + tools (DEBUG / INFO / WARNING)
LOG_LEVEL=WARNING
